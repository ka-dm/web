<templates>
    <t t-inherit="web.NavBar.AppsMenu" t-inherit-mode="extension">
        
        <xpath expr="//t[@t-if='env.isSmall']" position="attributes">
            <attribute name="t-if">false</attribute>
        </xpath>
        
        
        <xpath expr="//Dropdown" position="replace">

            <t t-if="env.isSmall">
                <a href="/odoo" class="o_menu_toggle border-0" t-att-class="{'hasImage': currentApp?.webIconData}" accesskey="h" t-ref="menuApps" t-on-click.prevent="_openAppMenuSidebar">
                    <t t-call="web.NavBar.AppsMenu.Sidebar"/>
                </a>
            </t>
            <t t-else="">
            </t>
            <AppsMenu>
                <t t-set-slot="search_bar">
                    <AppsMenuSearchBar />
                </t>
                <AppMenuItem
                    t-foreach="apps"
                    t-as="app"
                    t-key="app.id"
                    app="app"
                    currentApp="currentApp"
                    href="getMenuItemHref(app)"
                    onClick="onNavBarDropdownItemSelection.bind(this)"
                />
            </AppsMenu>

        </xpath>
    </t>

    <!-- Apps menu -->
    <t t-name="web_responsive.AppsMenu">
        <div class="o_grid_apps_menu" t-att-data-theme="theme">

            <a href="/odoo" name="o_grid_apps_menu__button" class="o_grid_apps_menu__button o_menu_toggle border-0 hasImage" title="Home Menu" data-hotkey="h" t-on-click.stop="onMenuClick">
                <svg t-if="!env.isSmall" class="o_menu_toggle_icon pe-none" width="14px" height="14px" viewBox="0 0 14 14"
                    xmlns="http://www.w3.org/2000/svg">
                    <g t-foreach="[0, 5, 10]" t-as="Y" t-att-id="'o_menu_toggle_row_' + Y_index" fill="currentColor" t-key="'o_menu_toggle_row_' + Y_index">
                        <rect t-foreach="[0, 5, 10]" t-as="X" width="3" height="3" t-att-x="X" t-att-y="Y" t-key="'o_menu_toggle_cell_' + X_index"/>
                    </g>
                </svg>
                <img t-if="!env.isSmall and currentApp" t-att-src="currentApp.webIconData" class="o_menu_brand_icon d-inline position-absolute start-0 h-100 ps-1 ms-2" t-att-alt="currentApp.name" t-ref="appIcon"/>
                <span t-if="!env.isSmall and currentApp" t-out="currentApp.name" class="o_menu_brand d-flex ms-3 pe-0"/>
            </a>

            <!-- <button name="o_grid_apps_menu__button" class="o_grid_apps_menu__button o_menu_toggle border-0 hasImage" title="Home Menu" data-hotkey="h" t-on-click.stop="onMenuClick" style="visibility: hidden;">
                <svg t-if="!env.isSmall" class="o_menu_toggle_icon pe-none" width="14px" height="14px" viewBox="0 0 14 14"
                    xmlns="http://www.w3.org/2000/svg">
                    <g t-foreach="[0, 5, 10]" t-as="Y" t-att-id="'o_menu_toggle_row_' + Y_index" fill="currentColor" t-key="'o_menu_toggle_row_' + Y_index">
                        <rect t-foreach="[0, 5, 10]" t-as="X" width="3" height="3" t-att-x="X" t-att-y="Y" t-key="'o_menu_toggle_cell_' + X_index"/>
                    </g>
                </svg>
                <img t-if="!env.isSmall and currentApp" t-att-src="currentApp.webIconData" class="o_menu_brand_icon d-inline position-absolute start-0 h-100 ps-1 ms-2" t-att-alt="currentApp.name" t-ref="appIcon"/>
                <span t-if="!env.isSmall and currentApp" t-out="currentApp.name" class="o_menu_brand d-flex ms-3 pe-0"/>
            </button> -->

            <div t-if="state.open" class="app-menu-container">
                <t t-slot="search_bar" />
                <div class="o-app-menu-list">
                    <t t-slot="default" />
                </div>
            </div>
        </div>
    </t>

    <!-- Apps Menu Sidebar -->
    <t t-inherit="web.NavBar.AppsMenu.Sidebar" t-inherit-mode="extension">
    <xpath expr="//small" position="replace">
        <div class="d-flex align-items-center justify-content-between ms-2">
            <button class="btn btn-primary" t-on-click="onCustomButtonClick">
                <i class="oi oi-apps"></i>
                <span class="px-2">All Apps</span>
            </button>
        </div>
    </xpath>
    </t>
    

</templates>
